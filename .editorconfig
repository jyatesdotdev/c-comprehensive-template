# EditorConfig — https://editorconfig.org
# Authoritative C formatting lives in .clang-format; this covers everything else.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[{CMakeLists.txt,*.cmake}]
indent_size = 4

[Makefile]
indent_style = tab
