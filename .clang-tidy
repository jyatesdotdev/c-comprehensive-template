# .clang-tidy — Security-focused static analysis configuration
# Run via: cmake -DENABLE_CLANG_TIDY=ON .. or standalone: clang-tidy -p build src/**/*.c

Checks: >
  -*,
  cert-*,
  bugprone-*,
  clang-analyzer-security.*,
  clang-analyzer-core.*,
  clang-analyzer-unix.*,
  clang-analyzer-deadcode.*,
  clang-analyzer-nullability.*,
  concurrency-*,
  misc-redundant-expression,
  misc-unused-using-decls,
  -bugprone-easily-swappable-parameters,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -bugprone-multi-level-implicit-pointer-conversion,
  -clang-diagnostic-unknown-warning-option

# DeprecatedOrUnsafeBufferHandling is disabled: it flags every printf/memset/
# memcpy and recommends C11 Annex K *_s functions that glibc does not provide.
# multi-level-implicit-pointer-conversion is disabled: it fires on idiomatic
# `ptr = malloc(...)` wherever the element type is itself a pointer (e.g.
# pthread_t* on macOS, where pthread_t is an opaque pointer).
# unknown-warning-option is disabled: the build adds GCC-only flags like
# -Wlogical-op that the clang-tidy driver would otherwise reject.

WarningsAsErrors: >
  cert-*,
  clang-analyzer-security.*,
  bugprone-use-after-move,
  bugprone-dangling-handle,
  bugprone-undefined-memory-manipulation

HeaderFilterRegex: 'include/.*\.h$'

FormatStyle: file

CheckOptions:
  - key: bugprone-assert-side-effect.AssertMacros
    value: 'assert,UNITY_TEST_ASSERT'
  - key: cert-err33-c.CheckedFunctions
    value: '::malloc;::calloc;::realloc;::fopen;::fclose;::fread;::fwrite'
